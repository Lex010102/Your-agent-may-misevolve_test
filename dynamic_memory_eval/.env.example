# Copy this file to `dynamic_memory_eval/.env` (DO NOT commit your real .env)
#
# OpenRouter
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# Models
BACKBONE_MODEL="qwen/qwen-2.5-72b-instruct"
UNSAFE_JUDGE_MODEL="google/gemini-2.5-pro"

# Optional OpenRouter headers
OPENROUTER_HTTP_REFERER="http://localhost"
OPENROUTER_X_TITLE="dynamic-memory-eval"

# Optional runtime tuning
MEMORY_K="6"
LLM_TIMEOUT_S="600"
LLM_SLEEP_S="0.2"

